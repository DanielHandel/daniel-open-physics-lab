        "func": "if (msg.topic === \"heizung/2\") flow.set(\"hk2_heizung\", msg.payload);\nelse if (msg.topic === \"aussentemp\") flow.set(\"global_aussen\", msg.payload);\nelse if (msg.topic === \"frostschutz/2\") flow.set(\"hk2_frost\", msg.payload);\nelse if (msg.topic === \"HK 2\") flow.set(\"hk2_timer\", msg.payload);\nelse if (msg.topic === \"soll0/2\") flow.set(\"hk2_soll0\", msg.payload);\nelse if (msg.topic === \"soll10/2\") flow.set(\"hk2_soll10\", msg.payload);\n\nvar heizung = flow.get(\"hk2_heizung\") || false;\nvar aussen = flow.get(\"global_aussen\") || 0;\nvar frost = flow.get(\"hk2_frost\");\nif (frost === undefined) frost = 3;\n\nvar soll0 = flow.get(\"hk2_soll0\");\nif (soll0 === undefined) soll0 = 40; // Default-Wert bei 0°C\nvar soll10 = flow.get(\"hk2_soll10\");\nif (soll10 === undefined) soll10 = 30; // Default-Wert bei 10°C\n\nvar timerRaw = flow.get(\"hk2_timer\");\nvar timerAktiv = (timerRaw === true || timerRaw === \"ON\" || timerRaw === \"on\" || timerRaw === 1);\n\n// Heizkurve linear berechnen: y = m*x + b\nvar m = (soll10 - soll0) / 10.0;\nvar solltemp = (m * aussen) + soll0;\nsolltemp = Math.round(solltemp * 10) / 10;\n\nif (solltemp > 65) solltemp = 65;\nif (solltemp < 20) solltemp = 20;\n\nvar statusText = \"Pumpe AUS\";\nvar isFrostActive = (aussen < frost);\nvar wasFrostActive = flow.get(\"hk2_frost_active\") || false;\nvar toastMsg = null;\n\nif (isFrostActive && !wasFrostActive) {\n    toastMsg = { payload: \"ACHTUNG: Frostgefahr! Frostschutz-Pumpe HK2 aktiviert.\" };\n}\nflow.set(\"hk2_frost_active\", isFrostActive);\n\nif (isFrostActive) statusText = \"Pumpe EIN (Frostschutz aktiv!)\";\nelse if (heizung && timerAktiv) statusText = \"Pumpe EIN (Tagbetrieb)\";\nelse if (heizung && !timerAktiv) statusText = \"Pumpe AUS (Nachtabsenkung)\";\nelse statusText = \"Pumpe AUS (Hauptschalter AUS)\";\n\nreturn [\n    { payload: statusText }, \n    { payload: solltemp },\n    toastMsg,\n    null\n];",
