    {
        "id": "flow_context_gate",
        "type": "function",
        "z": "e9c238bd3128efbf",
        "name": "Modus in Speicher sichern",
        "func": "// Wir speichern den Zustand (true/false) im globalen Flow-Speicher\nflow.set(\"automatik_aktiv\", msg.payload);\n\n// Wenn ausgeschaltet, senden wir einen Reset-Befehl an die Schleife\nif (msg.payload === false) {\n    msg.payload = \"stop\";\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
