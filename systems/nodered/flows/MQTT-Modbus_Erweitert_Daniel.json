    {
        "id": "knight_rider_logic",
        "type": "function",
        "z": "e9c238bd3128efbf",
        "name": "Knight Rider Logik (Modbus)",
        "func": "// Aktuellen Schritt aus dem Speicher holen (oder bei 0 starten)\nlet schritt = context.get(\"schritt\") || 0;\nlet richtung = context.get(\"richtung\") || 1; // 1 = vorwärts, -1 = rückwärts\n\n// Array für alle 8 Relais vorbereiten (Standard alle aus)\nlet relaisStati = [false, false, false, false, false, false, false, false];\n\n// Nur das aktuelle Relais einschalten\nrelaisStati[schritt] = true;\n\n// Nächsten Schritt berechnen\nschritt += richtung;\n\n// Wenn wir am Ende (Relais 8) angekommen sind, Richtung umkehren\nif (schritt >= 7) {\n    schritt = 7;\n    richtung = -1;\n}\n// Wenn wir am Anfang (Relais 1) angekommen sind, Richtung umkehren\nif (schritt <= 0) {\n    schritt = 0;\n    richtung = 1;\n}\n\n// Werte für den nächsten Durchlauf speichern\ncontext.set(\"schritt\", schritt);\ncontext.set(\"richtung\", richtung);\n\n// Modbus-Anweisung zusammenbauen (FC15: Write Multiple Coils)\nmsg.payload = relaisStati;\nmsg.topic = \"writeMultiple\";\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 240,
        "wires": [
            [
                "modbus_write_multiple",
                "trigger_loop"
            ]
        ]
    },
