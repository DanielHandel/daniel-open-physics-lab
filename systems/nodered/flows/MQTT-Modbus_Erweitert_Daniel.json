    {
        "id": "check_automatik_active",
        "type": "function",
        "z": "e9c238bd3128efbf",
        "name": "Prüfe ob Automatik aktiv",
        "func": "// Wir schauen in den Flow-Speicher, ob die Automatik läuft\nlet automatikAktiv = flow.get(\"automatikAktiv\") || false;\n\n// Wenn die Automatik läuft, blockieren wir den manuellen Befehl (return null)\nif (automatikAktiv === true) {\n    return null;\n}\n\n// Wenn Automatik AUS ist, konvertieren wir den Befehl für Modbus\nif (msg.payload === \"true\" || msg.payload === true || msg.payload === 1 || msg.payload === \"1\") {\n    msg.payload = true;\n} else {\n    msg.payload = false;\n}\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 300,
